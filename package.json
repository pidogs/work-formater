{
  "name": "c-table-formatter",
  "displayName": "C Table Formatter",
  "description": "Aligns columns in C struct array initializer tables",
  "publisher": "David-E",
  "author": {
    "name": "David-E"
  },
  "version": "0.0.1",
  "devDependencies": {
    "@types/vscode": "^1.85.0"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Formatters"],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cTableFormatter.format",
        "title": "Format C Table"
      }
    ],
    "keybindings": [
      {
        "command": "cTableFormatter.format",
        "key": "ctrl+alt+w",
        "mac": "cmd+alt+w",
        "when": "editorTextFocus"
      }
    ]
  }
}